# Copy to .env and fill in. The demo runs WITHOUT these (deterministic mock mode),
# but real LLM reasoning + Weave traces need them.

# ─── W&B Inference Service + Weave (primary path) ────────────────────────────
# All four agents run on W&B-hosted open models via the OpenAI-compatible
# endpoint, and every call is Weave-traced. Get a key at https://wandb.ai/authorize
WANDB_API_KEY=
# REQUIRED, and must be "team/project" (team = your W&B entity, usually your
# username if solo), e.g. paramjeet/war-room. Used by both Weave AND usage tracking.
WANDB_PROJECT=

# Optional model overrides (defaults shown):
#   investigators: meta-llama/Llama-3.3-70B-Instruct  (drop to ...-3.1-8B if rate-limited)
#   commander:     deepseek-ai/DeepSeek-R1-0528        (reasoning model; ~10-25s)
# WARROOM_INVESTIGATOR_MODEL=meta-llama/Llama-3.3-70B-Instruct
# WARROOM_COMMANDER_MODEL=deepseek-ai/DeepSeek-R1-0528

# ─── OpenAI (alternative path) ───────────────────────────────────────────────
# Used only if WANDB_API_KEY/WANDB_PROJECT are NOT both set.
# gpt-4o-mini investigators, gpt-4o Commander.
OPENAI_API_KEY=

# Optional: disable demo pacing (the staggered node animation): WARROOM_PACING=0
