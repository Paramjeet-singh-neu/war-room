# Copy to .env and fill in. The demo runs WITHOUT these (deterministic mock mode),
# but real LLM reasoning + Weave traces need them.

# OpenAI: investigators use gpt-4o-mini, the Commander uses gpt-4o.
OPENAI_API_KEY=

# Weights & Biases / Weave. Get a key at https://wandb.ai/authorize
# Easiest: run `wandb login` once instead of setting this.
WANDB_API_KEY=
# Optional: your W&B entity (team/username). Helps weave.init pick the project owner.
WANDB_ENTITY=
